Notebook[{
Cell[TextData[{"Condensed Invariant Polynomials\nSource: output_elec\nCondensation: P -> P0+dP, Mz -> Mz0+dMz"}], "Title"],

Cell[BoxData["{dP, dMz, ε, Qx, Qy, Ex, Ey, Mx, My, P0, Mz0}"], "Input"],

Cell[BoxData["
beta1 = 2*Mz0*alpha7
beta2 = alpha1

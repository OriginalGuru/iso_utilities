"], "Input"],

Cell[BoxData["invariants = {
  dMz,  (* deg 1 *)
  ε,  (* deg 1 *)
  dP,  (* deg 1 *)
  dMz^2,  (* deg 2 *)
  dMz*ε,  (* deg 2 *)
  ε^2,  (* deg 2 *)
  dP^2,  (* deg 2 *)
  Qx^2 + Qy^2,  (* deg 2 *)
  Ex*Qx + Ey*Qy,  (* deg 2 *)
  Ex^2 + Ey^2,  (* deg 2 *)
  Mx^2 + My^2,  (* deg 2 *)
  dMz*dP,  (* deg 2 *)
  Mx*Qx + My*Qy,  (* deg 2 *)
  Ex*Mx + Ey*My,  (* deg 2 *)
  dP*ε,  (* deg 2 *)
  dMz^2*ε,  (* deg 3 *)
  dMz*ε^2,  (* deg 3 *)
  dMz*dP^2,  (* deg 3 *)
  Qx^2*dMz + Qy^2*dMz,  (* deg 3 *)
  Ex*Qx*dMz + Ey*Qy*dMz,  (* deg 3 *)
  Ex^2*dMz + Ey^2*dMz,  (* deg 3 *)
  Mx^2*dMz + My^2*dMz,  (* deg 3 *)
  dMz^3,  (* deg 3 *)
  Mx*Qx*dP + My*Qy*dP,  (* deg 3 *)
  Ex*Mx*dP + Ey*My*dP,  (* deg 3 *)
  ε^3,  (* deg 3 *)
  dP^2*ε,  (* deg 3 *)
  Qx^2*ε + Qy^2*ε,  (* deg 3 *)
  Ex*Qx*ε + Ey*Qy*ε,  (* deg 3 *)
  Ex^2*ε + Ey^2*ε,  (* deg 3 *)
  Mx^2*ε + My^2*ε,  (* deg 3 *)
  dMz*dP*ε,  (* deg 3 *)
  Mx*Qx*ε + My*Qy*ε,  (* deg 3 *)
  Ex*Mx*ε + Ey*My*ε,  (* deg 3 *)
  Mx*Qx*dMz + My*Qy*dMz,  (* deg 3 *)
  Ex*Mx*dMz + Ey*My*dMz,  (* deg 3 *)
  dMz^2*dP,  (* deg 3 *)
  dP^3,  (* deg 3 *)
  Qx^2*dP + Qy^2*dP,  (* deg 3 *)
  Ex*Qx*dP + Ey*Qy*dP,  (* deg 3 *)
  Ex^2*dP + Ey^2*dP,  (* deg 3 *)
  Mx^2*dP + My^2*dP,  (* deg 3 *)
  dP*ε^2,  (* deg 3 *)
};"], "Input"],

Cell[BoxData["F = (
  beta1 * (dMz) +
  beta2 * (ε) +

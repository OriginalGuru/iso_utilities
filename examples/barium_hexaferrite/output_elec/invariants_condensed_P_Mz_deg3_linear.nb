  beta32 * (dMz*dP*ε) +
  beta33 * (Mx*Qx*ε + My*Qy*ε) +
  beta34 * (Ex*Mx*ε + Ey*My*ε) +
  beta35 * (Mx*Qx*dMz + My*Qy*dMz) +
  beta36 * (Ex*Mx*dMz + Ey*My*dMz) +
  beta37 * (dMz^2*dP) +
  beta38 * (dP^3) +
  beta39 * (Qx^2*dP + Qy^2*dP) +

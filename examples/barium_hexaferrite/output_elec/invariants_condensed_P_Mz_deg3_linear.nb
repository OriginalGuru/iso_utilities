  beta22 * (Mx^2*dMz + My^2*dMz) +
  beta23 * (dMz^3) +
  beta24 * (Mx*Qx*dP + My*Qy*dP) +
  beta25 * (Ex*Mx*dP + Ey*My*dP) +
  beta26 * (ε^3) +
  beta27 * (dP^2*ε) +
  beta28 * (Qx^2*ε + Qy^2*ε) +
  beta29 * (Ex*Qx*ε + Ey*Qy*ε) +

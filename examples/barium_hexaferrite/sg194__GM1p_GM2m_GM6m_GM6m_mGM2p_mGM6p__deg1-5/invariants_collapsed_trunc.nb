  c13 * (Ex*P^2*Qx + Ey*P^2*Qy) +
  c14 * (Ex^2*P^2 + Ey^2*P^2) +
  c15 * (Mz^2*P^2) +
  c16 * (Mx^2*P^2 + My^2*P^2) +
  c17 * (Mx*Mz*P*Qx + My*Mz*P*Qy) +
  c18 * (Ex*Mx*Mz*P + Ey*My*Mz*P) +
  c19 * (Ex^2*Qx^2 + 2*Ex*Ey*Qx*Qy + Ey^2*Qy^2) +
  c20 * (Ex^2*Qx^2 + Ex^2*Qy^2 + Ey^2*Qx^2 + Ey^2*Qy^2) +
  c21 * (Mz^2*Qx^2 + Mz^2*Qy^2) +
  c22 * (Mx^2*Qx^2 + Mx^2*Qy^2 + My^2*Qx^2 + My^2*Qy^2) +
  c23 * (3*Mx^2*Qx^2 + Mx^2*Qy^2 + 4*Mx*My*Qx*Qy + My^2*Qx^2 + 3*My^2*Qy^2) +
  c24 * (Ex*Mz^2*Qx + Ey*Mz^2*Qy) +
  c25 * (Ex*Mx^2*Qx + Ex*My^2*Qx + Ey*Mx^2*Qy + Ey*My^2*Qy) +
  c26 * (3*Ex*Mx^2*Qx + 2*Ex*Mx*My*Qy + Ex*My^2*Qx + Ey*Mx^2*Qy + 2*Ey*Mx*My*Qx + 3*Ey*My^2*Qy) +
  c27 * (Ex^2*Mz^2 + Ey^2*Mz^2) +
  c28 * (Ex^2*Mx^2 + Ex^2*My^2 + Ey^2*Mx^2 + Ey^2*My^2) +
  c29 * (3*Ex^2*Mx^2 + Ex^2*My^2 + 4*Ex*Ey*Mx*My + Ey^2*Mx^2 + 3*Ey^2*My^2) +
  c30 * (Mz^4) +
  c31 * (Mx^2*Mz^2 + My^2*Mz^2) +
  c32 * (Mx*Mz*P*Qx*ε + My*Mz*P*Qy*ε) +
  c33 * (Ex*Mx*Mz*P*ε + Ey*My*Mz*P*ε) +
  c34 * (Ex*Mz^2*Qx*ε + Ey*Mz^2*Qy*ε) +
  c35 * (Mz^4*ε)
);"], "Input"]


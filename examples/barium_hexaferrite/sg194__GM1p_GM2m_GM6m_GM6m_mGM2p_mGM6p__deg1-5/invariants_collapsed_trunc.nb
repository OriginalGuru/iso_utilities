Cell[BoxData["invariants = {
  ε,  (* deg 1 *)
  ε^2,  (* deg 2 *)
  P^2,  (* deg 2 *)
  Qx^2 + Qy^2,  (* deg 2 *)
  Ex*Qx + Ey*Qy,  (* deg 2 *)
  Ex^2 + Ey^2,  (* deg 2 *)
  Mz^2,  (* deg 2 *)
  Mx^2 + My^2,  (* deg 2 *)
  Ex*Qx*ε + Ey*Qy*ε,  (* deg 3 *)
  Mz^2*ε,  (* deg 3 *)
  Mz^2*ε^2,  (* deg 4 *)
  P^2*Qx^2 + P^2*Qy^2,  (* deg 4 *)
  Ex*P^2*Qx + Ey*P^2*Qy,  (* deg 4 *)
  Ex^2*P^2 + Ey^2*P^2,  (* deg 4 *)
  Mz^2*P^2,  (* deg 4 *)
  Mx^2*P^2 + My^2*P^2,  (* deg 4 *)
  Mx*Mz*P*Qx + My*Mz*P*Qy,  (* deg 4 *)
  Ex*Mx*Mz*P + Ey*My*Mz*P,  (* deg 4 *)
  Ex^2*Qx^2 + 2*Ex*Ey*Qx*Qy + Ey^2*Qy^2,  (* deg 4 *)
  Ex^2*Qx^2 + Ex^2*Qy^2 + Ey^2*Qx^2 + Ey^2*Qy^2,  (* deg 4 *)
  Mz^2*Qx^2 + Mz^2*Qy^2,  (* deg 4 *)
  Mx^2*Qx^2 + Mx^2*Qy^2 + My^2*Qx^2 + My^2*Qy^2,  (* deg 4 *)
  3*Mx^2*Qx^2 + Mx^2*Qy^2 + 4*Mx*My*Qx*Qy + My^2*Qx^2 + 3*My^2*Qy^2,  (* deg 4 *)
  Ex*Mz^2*Qx + Ey*Mz^2*Qy,  (* deg 4 *)
  Ex*Mx^2*Qx + Ex*My^2*Qx + Ey*Mx^2*Qy + Ey*My^2*Qy,  (* deg 4 *)
  3*Ex*Mx^2*Qx + 2*Ex*Mx*My*Qy + Ex*My^2*Qx + Ey*Mx^2*Qy + 2*Ey*Mx*My*Qx + 3*Ey*My^2*Qy,  (* deg 4 *)
  Ex^2*Mz^2 + Ey^2*Mz^2,  (* deg 4 *)
  Ex^2*Mx^2 + Ex^2*My^2 + Ey^2*Mx^2 + Ey^2*My^2,  (* deg 4 *)
  3*Ex^2*Mx^2 + Ex^2*My^2 + 4*Ex*Ey*Mx*My + Ey^2*Mx^2 + 3*Ey^2*My^2,  (* deg 4 *)
  Mz^4,  (* deg 4 *)
  Mx^2*Mz^2 + My^2*Mz^2,  (* deg 4 *)
  Mx*Mz*P*Qx*ε + My*Mz*P*Qy*ε,  (* deg 5 *)
  Ex*Mx*Mz*P*ε + Ey*My*Mz*P*ε,  (* deg 5 *)
  Ex*Mz^2*Qx*ε + Ey*Mz^2*Qy*ε,  (* deg 5 *)
  Mz^4*ε,  (* deg 5 *)
};"], "Input"],

Cell[BoxData["F = (
  c1 * (ε) +
  c2 * (ε^2) +
  c3 * (P^2) +
  c4 * (Qx^2 + Qy^2) +
  c5 * (Ex*Qx + Ey*Qy) +
  c6 * (Ex^2 + Ey^2) +
  c7 * (Mz^2) +
